{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --packages=external",
    "build:lambda": "tsc --noEmit && esbuild src/lambda.ts src/sqs-handler.ts src/migrate.ts src/daily-report.ts --bundle --platform=node --outdir=dist --target=node22 --external:@aws-sdk/*",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/client-ses": "^3.1012.0",
    "@aws-sdk/client-sqs": "^3.1024.0",
    "@aws-sdk/rds-signer": "^3.1012.0",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.3",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
